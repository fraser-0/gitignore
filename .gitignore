# Project specific ignores
#
# Add any project specific ignores here.

# OS
#
# Ignore all files that the OS automatically creates in a directory.
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDEs
#
# Ignore all files that IDEs automatically create in a directory.
.fleet
.idea
*.iml
misc.xml
deploymentTargetDropDown.xml
render.experimental.xml
.vscode
# .vscode/*
# !.vscode/settings.json
# !.vscode/tasks.json
# !.vscode/launch.json
# !.vscode/extensions.json
.zed

# Sensitive
#
# Ignore sensitive files that should not be shared.
*.cer
.env
.env*
!.env.example
!.env.template
*.gpg
*.jks
*.jwks
*.key
*.key.pub
*.keystore
*.p8
*.p12
*.pem
*.pid

# Packages
#
# It's better to unpack these files and commit the raw source
# git has its own built in compression methods.
*.7z
*.dmg
*.gz
*.iso
*.jar
*.rar
*.tar
*.tar.gz
*.zip
*.war
*.nar
*.ear

# Compiled source
*.com
*.class
*.dll
*.exe
*.o
*.so

# Databases
*.csv
*.sqlite
*.sqlite3
*azurite*.json

# Language ignores below here
